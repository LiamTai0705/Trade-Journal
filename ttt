function openModal(type, id){
  if(type==='trade'){
    editingTradeId=id;
    const t=id?trades.find(x=>x.id===id):null;
    document.getElementById('tradeModalTitle').textContent=id?`вңҸпёҸ з·ЁијҜдәӨжҳ“ вҖ” ${id}`:'вһ• ж–°еўһдәӨжҳ“';
    document.getElementById('btnDelete').style.display=id?'block':'none';
    const today=new Date().toISOString().slice(0,10);
    setValue('t-date', t?t.date:today);
    setSelect('t-inst', t?t.inst:'NQ');
    setSelect('t-dir', t?t.dir:'LONG');
    setSelect('t-setup', t?t.setup:'OB иЁӮе–®еҚҖеЎҠ');
    setSelect('t-session', t?t.session:'зҙҗзҙ„ AM');
    setSelect('t-window', t?t.window:'9-10am');
    setSelect('t-firm', t?t.firm:'Apex Trader');
    setSelect('t-quality', t?t.quality:'A');
    setValue('t-pl', t?t.pl:'');
    setValue('t-r', t?t.r:'');
    setSelect('t-rating', t?String(t.rating):'4');
    setSelect('t-result', t?t.result:'WIN');
    setSelect('t-rules', t?(t.rules?'вң… жҳҜ':'вқҢ еҗҰ'):'вң… жҳҜ');
    setSelect('t-be', t?(t.be?'вң… жҳҜ':'вқҢ еҗҰ'):'вқҢ еҗҰ');
    setValue('t-reason', t?t.reason:'');
    setValue('t-note', t?t.note:'');
    // multi-selects
    ['t-pos','t-neg'].forEach(sid=>{
      const sel=document.getElementById(sid);
      const vals=t?(sid==='t-pos'?t.pos:t.neg):[];
      Array.from(sel.options).forEach(o=>o.selected=vals.includes(o.value));
    });
    document.getElementById('tradeOverlay').classList.add('open');
  }
  else if(type==='review-entry'){
    const today=new Date().toISOString().slice(0,10);
    setValue('r-date',today);setSelect('r-mood','рҹ”ө еҶ·йқңиҮӘеҫӢ');
    setValue('r-plan','');setValue('r-review','');setValue('r-lesson','');
    setValue('r-count','');setValue('r-pl','');
    setSelect('r-adherence','100% вҖ” е®ҢзҫҺ');
    document.getElementById('reviewOverlay').classList.add('open');
  }
  else if(type==='missed'){
    const today=new Date().toISOString().slice(0,10);
    setValue('ms-date',today);
    document.getElementById('missedOverlay').classList.add('open');
  }
}
function closeModals(){
  document.querySelectorAll('.overlay').forEach(o=>o.classList.remove('open'));
  editingTradeId=null;
}
function setValue(id,v){const el=document.getElementById(id);if(el)el.value=v;}
function setSelect(id,v){
  const el=document.getElementById(id);if(!el)return;
  const opt=Array.from(el.options).find(o=>o.value===v||o.text===v||o.value.startsWith(v)||v&&v.toString().startsWith(o.value));
  if(opt)el.value=opt.value;else el.value=v;
}
function getSelectedMulti(id){return Array.from(document.getElementById(id).selectedOptions).map(o=>o.value);}

function saveTrade(){
  const pl=parseFloat(document.getElementById('t-pl').value)||0;
  const r=parseFloat(document.getElementById('t-r').value)||0;
  const dir=document.getElementById('t-dir').value.split(' ')[0];
  const result=document.getElementById('t-result').value.split(' ')[0];
  const newT={
    id: editingTradeId||(trades.length>0?'TRD-'+String(Math.max(...trades.map(t=>parseInt(t.id.split('-')[1]||0)))+1).padStart(3,'0'):'TRD-001'),
    date:document.getElementById('t-date').value,
    inst:document.getElementById('t-inst').value,
    dir,
    setup:document.getElementById('t-setup').value,
    session:document.getElementById('t-session').value,
    window:document.getElementById('t-window').value,
    firm:document.getElementById('t-firm').value,
    quality:document.getElementById('t-quality').value,
    pl,r,
    rating:parseInt(document.getElementById('t-rating').value),
    result,
    rules:document.getElementById('t-rules').value==='вң… жҳҜ',
    be:document.getElementById('t-be').value==='вң… жҳҜ',
    pos:getSelectedMulti('t-pos'),
    neg:getSelectedMulti('t-neg'),
    reason:document.getElementById('t-reason').value,
    note:document.getElementById('t-note').value
  };
  if(editingTradeId){ const idx=trades.findIndex(t=>t.id===editingTradeId);if(idx>=0)trades[idx]=newT;else trades.push(newT); }
  else trades.push(newT);
  save('ers_trades',trades);
  closeModals();
  showTab(currentTab);
}

function deleteTrade(){
  if(!editingTradeId)return;
  if(!confirm(`зўәе®ҡиҰҒеҲӘйҷӨдәӨжҳ“ ${editingTradeId}пјҹ`))return;
  trades=trades.filter(t=>t.id!==editingTradeId);
  save('ers_trades',trades);
  closeModals();
  showTab(currentTab);
}

function saveReview(){
  const today=document.getElementById('r-date').value;
  reviews.push({
    id:'R-'+String(reviews.length+1).padStart(3,'0'),
    date:today,
    mood:document.getElementById('r-mood').value,
    plan:document.getElementById('r-plan').value,
    review:document.getElementById('r-review').value,
    lesson:document.getElementById('r-lesson').value,
    count:parseInt(document.getElementById('r-count').value)||0,
    pl:parseFloat(document.getElementById('r-pl').value)||0,
    adherence:document.getElementById('r-adherence').value
  });
  save('ers_reviews',reviews);
  closeModals();
  if(currentTab==='review')showTab('review');
}

function saveMissed(){
  missedTrades.push({
    id:'M-'+String(missedTrades.length+1).padStart(3,'0'),
    date:document.getElementById('ms-date').value,
    inst:document.getElementById('ms-inst').value,
    dir:document.getElementById('ms-dir').value.split(' ')[0],
    setup:document.getElementById('ms-setup').value,
    r:parseFloat(document.getElementById('ms-r').value)||0,
    why:document.getElementById('ms-why').value,
    note:document.getElementById('ms-note').value,
    lesson:document.getElementById('ms-lesson').value
  });
  save('ers_missed',missedTrades);
  closeModals();
  if(currentTab==='missed')showTab('missed');
}

// Month nav
function changeMonth(d){
  viewMonth+=d;
  if(viewMonth>11){viewMonth=0;viewYear++;}
  if(viewMonth<0){viewMonth=11;viewYear--;}
  document.getElementById('monthLabel').textContent=`${viewYear}е№ҙ${MONTHS[viewMonth]}`;
  if(currentTab==='dashboard')renderCalendar();
}
document.getElementById('monthLabel').textContent=`${viewYear}е№ҙ${MONTHS[viewMonth]}`;

// Close on backdrop
document.querySelectorAll('.overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)closeModals();}));

// Init
showTab('dashboard');
</script>
