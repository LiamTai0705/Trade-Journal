<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>1% ERS дәӨжҳ“ж—ҘиӘҢ</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg:#f5f5f5; --card:#fff; --border:#ebebeb;
  --text:#1a1a1a; --muted:#888; --light:#f9f9f9;
  --green:#16a34a; --green-bg:#dcfce7; --green-light:#f0fdf4;
  --red:#dc2626; --red-bg:#fee2e2; --red-light:#fff5f5;
  --blue:#2563eb; --purple:#7c3aed;
  --accent:#1a1a1a; --radius:12px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}

/* в”Җв”Җ App Shell в”Җв”Җ */
.app{display:flex;min-height:100vh;}
.sidebar{width:210px;background:var(--card);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:20px 14px;gap:24px;flex-shrink:0;}
.main{flex:1;overflow:hidden;display:flex;flex-direction:column;}

/* в”Җв”Җ Brand в”Җв”Җ */
.brand{display:flex;align-items:center;gap:10px;padding-bottom:16px;border-bottom:1px solid var(--border);}
.brand-logo{width:36px;height:36px;background:#1a1a1a;border-radius:9px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:12px;letter-spacing:-0.5px;}
.brand-text .name{font-size:14px;font-weight:800;letter-spacing:-0.5px;}
.brand-text .sub{font-size:11px;color:var(--muted);margin-top:1px;}

/* в”Җв”Җ Nav в”Җв”Җ */
.nav-section{display:flex;flex-direction:column;gap:3px;}
.nav-label{font-size:10px;font-weight:700;color:#bbb;letter-spacing:0.8px;text-transform:uppercase;padding:0 8px;margin-bottom:4px;}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--muted);transition:all .15s;}
.nav-item:hover{background:var(--light);color:var(--text);}
.nav-item.active{background:#f0f0f0;color:var(--text);font-weight:600;}
.nav-item .icon{font-size:15px;width:18px;text-align:center;}

/* в”Җв”Җ Quick Actions в”Җв”Җ */
.quick-actions{margin-top:auto;}
.quick-actions h4{font-size:11px;font-weight:700;color:#bbb;letter-spacing:0.8px;margin-bottom:8px;padding:0 2px;}
.btn-qa{display:flex;align-items:center;gap:7px;width:100%;padding:8px 10px;border:1.5px solid var(--border);border-radius:8px;background:#fff;cursor:pointer;font-size:12px;font-weight:600;color:var(--text);transition:all .15s;margin-bottom:6px;}
.btn-qa:hover{background:var(--light);border-color:#ccc;}
.btn-qa .plus{color:var(--green);font-size:15px;font-weight:700;}

/* в”Җв”Җ Topbar в”Җв”Җ */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;border-bottom:1px solid var(--border);background:var(--card);}
.topbar-tabs{display:flex;gap:2px;}
.tab-btn{padding:6px 14px;border-radius:7px;border:none;background:none;cursor:pointer;font-size:13px;font-weight:500;color:var(--muted);transition:all .15s;}
.tab-btn:hover{background:var(--light);}
.tab-btn.active{background:var(--accent);color:#fff;font-weight:600;}
.topbar-right{display:flex;align-items:center;gap:8px;}
.month-nav{display:flex;align-items:center;gap:6px;}
.month-nav button{background:none;border:1px solid var(--border);border-radius:6px;padding:4px 8px;cursor:pointer;color:var(--muted);font-size:13px;transition:all .15s;}
.month-nav button:hover{background:var(--light);}
#monthLabel{font-size:13px;font-weight:700;min-width:90px;text-align:center;}

/* в”Җв”Җ Content в”Җв”Җ */
.content{flex:1;overflow-y:auto;padding:20px 24px;}

/* в”Җв”Җ Stat Cards в”Җв”Җ */
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px;}
.stat-card{background:var(--card);border-radius:var(--radius);border:1px solid var(--border);padding:16px 18px;}
.stat-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.stat-head .lbl{font-size:11px;color:var(--muted);font-weight:500;}
.stat-val{font-size:24px;font-weight:800;letter-spacing:-1px;}
.stat-val.g{color:var(--green);}
.stat-val.r{color:var(--red);}
.stat-val.n{color:var(--text);}
.stat-sub{font-size:11px;color:var(--muted);margin-top:4px;}
.stat-sub .up{color:var(--green);}
.stat-sub .dn{color:var(--red);}

/* в”Җв”Җ Grid Layout в”Җв”Җ */
.two-col{display:grid;grid-template-columns:1fr 340px;gap:16px;margin-bottom:16px;}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;}
.card-title{font-size:12px;font-weight:700;color:var(--muted);letter-spacing:0.4px;margin-bottom:14px;text-transform:uppercase;}

/* в”Җв”Җ Calendar в”Җв”Җ */
.cal-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.cal-topbar{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border);}
.cal-topbar .title{font-size:13px;font-weight:700;}
.cal-stats{font-size:12px;color:var(--muted);}
.cal-stats span{font-weight:700;}
.cal-stats .gv{color:var(--green);}
.cal-header{display:grid;grid-template-columns:repeat(5,1fr) 80px;background:var(--light);border-bottom:1px solid var(--border);}
.cal-lbl{text-align:center;padding:8px 0;font-size:10px;font-weight:700;color:#bbb;letter-spacing:0.5px;}
.cal-grid{display:grid;grid-template-columns:repeat(5,1fr) 80px;}
.cal-cell{border-right:1px solid #f0f0f0;border-bottom:1px solid #f0f0f0;min-height:72px;padding:7px 9px;position:relative;}
.cal-cell:hover{background:#fafafa;}
.cal-cell.empty{background:var(--light);}
.cal-cell.win{background:var(--green-light);}
.cal-cell.loss{background:var(--red-light);}
.cal-cell.today .cal-d{background:#1a1a1a;color:#fff;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;}
.cal-d{font-size:11px;font-weight:600;color:#ccc;margin-bottom:4px;}
.cal-ct{font-size:10px;font-weight:600;color:#aaa;}
.cal-pl{font-size:13px;font-weight:800;letter-spacing:-0.3px;}
.cal-pl.g{color:var(--green);}
.cal-pl.r{color:var(--red);}
.cal-sum{background:#f9f9f9;border-right:none;display:flex;flex-direction:column;align-items:flex-end;justify-content:center;padding:6px 12px;}
.sum-lbl{font-size:9px;color:#bbb;letter-spacing:0.5px;margin-bottom:2px;}
.sum-ct{font-size:10px;color:#aaa;font-weight:600;}
.sum-pl{font-size:14px;font-weight:800;letter-spacing:-0.3px;}

/* в”Җв”Җ Charts в”Җв”Җ */
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;}
.chart-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px;}

/* в”Җв”Җ Table в”Җв”Җ */
.tbl-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.tbl-head{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border);}
.tbl-title{font-size:13px;font-weight:700;}
.search-box{padding:6px 12px;border:1px solid var(--border);border-radius:7px;font-size:12px;outline:none;width:180px;}
.search-box:focus{border-color:var(--accent);}
table{width:100%;border-collapse:collapse;}
thead tr th{text-align:left;padding:9px 14px;font-size:10px;font-weight:700;color:#bbb;letter-spacing:0.5px;background:var(--light);border-bottom:1px solid var(--border);}
tbody tr td{padding:9px 14px;font-size:12px;border-bottom:1px solid #f5f5f5;vertical-align:middle;}
tbody tr:last-child td{border-bottom:none;}
tbody tr:hover td{background:#fafafa;cursor:pointer;}
.badge{display:inline-flex;align-items:center;justify-content:center;padding:2px 9px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:0.3px;}
.badge.long{background:var(--green-bg);color:var(--green);}
.badge.short{background:var(--red-bg);color:var(--red);}
.badge.win{background:var(--green-bg);color:var(--green);}
.badge.loss{background:var(--red-bg);color:var(--red);}
.badge.be{background:#f3f4f6;color:#666;}
.pl-p{color:var(--green);font-weight:700;}
.pl-n{color:var(--red);font-weight:700;}
.rating-bar{display:flex;gap:2px;align-items:center;}
.rating-pip{width:12px;height:6px;border-radius:2px;background:#e5e7eb;}
.rating-pip.on{background:var(--green);}
.tag-wrap{display:flex;gap:3px;flex-wrap:wrap;}
.tag{padding:1px 6px;border-radius:4px;font-size:10px;font-weight:600;}
.tag.pos{background:var(--green-bg);color:var(--green);}
.tag.neg{background:var(--red-bg);color:var(--red);}

/* в”Җв”Җ Milestones в”Җв”Җ */
.milestone-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.ms-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;}
.ms-cat{font-size:10px;font-weight:700;letter-spacing:0.5px;margin-bottom:6px;}
.ms-title{font-size:14px;font-weight:700;margin-bottom:6px;}
.ms-target{font-size:12px;color:var(--muted);margin-bottom:10px;}
.ms-status{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.ms-status.achieved{background:var(--green-bg);color:var(--green);}
.ms-status.inprog{background:#dbeafe;color:var(--blue);}
.ms-status.notstart{background:#f3f4f6;color:#888;}

/* в”Җв”Җ Review в”Җв”Җ */
.review-tabs{display:flex;gap:8px;margin-bottom:16px;}
.rtab{padding:7px 16px;border-radius:8px;border:1.5px solid var(--border);background:#fff;cursor:pointer;font-size:12px;font-weight:600;color:var(--muted);transition:all .15s;}
.rtab.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.review-list{display:flex;flex-direction:column;gap:12px;}
.review-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;}
.rc-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.rc-date{font-size:11px;color:var(--muted);}
.rc-mood{font-size:12px;font-weight:700;}
.rc-mood.g{color:var(--green);}
.rc-mood.n{color:#888;}
.rc-mood.b{color:var(--red);}
.rc-section{margin-bottom:8px;}
.rc-lbl{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:0.4px;margin-bottom:3px;}
.rc-text{font-size:13px;color:var(--text);line-height:1.5;}

/* в”Җв”Җ Modal в”Җв”Җ */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:center;justify-content:center;}
.overlay.open{display:flex;}
.modal{background:#fff;border-radius:18px;padding:26px;width:520px;max-width:95vw;box-shadow:0 24px 64px rgba(0,0,0,.18);max-height:90vh;overflow-y:auto;}
.modal h2{font-size:15px;font-weight:800;margin-bottom:18px;display:flex;justify-content:space-between;align-items:center;}
.modal h2 .close-btn{background:none;border:none;cursor:pointer;color:#bbb;font-size:18px;padding:0 4px;}
.modal h2 .close-btn:hover{color:#333;}
.m-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.m-grid.single{grid-template-columns:1fr;}
.fg{display:flex;flex-direction:column;gap:4px;}
.fg.full{grid-column:1/-1;}
.fg label{font-size:10px;font-weight:700;color:#aaa;letter-spacing:0.5px;}
.fg input,.fg select,.fg textarea{padding:8px 11px;border:1.5px solid var(--border);border-radius:8px;font-size:13px;color:var(--text);outline:none;font-family:inherit;transition:border .15s;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:#1a1a1a;}
.fg textarea{resize:vertical;min-height:60px;}
.m-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:18px;}
.btn-cancel{padding:8px 18px;border:1.5px solid var(--border);border-radius:8px;background:#fff;cursor:pointer;font-size:12px;font-weight:600;}
.btn-save{padding:8px 18px;border:none;border-radius:8px;background:#1a1a1a;color:#fff;cursor:pointer;font-size:12px;font-weight:600;transition:opacity .15s;}
.btn-save:hover{opacity:.8;}
.btn-del{padding:8px 18px;border:none;border-radius:8px;background:#fee2e2;color:#dc2626;cursor:pointer;font-size:12px;font-weight:600;}
.btn-del:hover{background:#fecaca;}

/* в”Җв”Җ Misc в”Җв”Җ */
.section-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.section-hd h3{font-size:14px;font-weight:700;}
.btn-add{padding:7px 14px;border:1.5px solid var(--border);border-radius:8px;background:#fff;cursor:pointer;font-size:12px;font-weight:600;display:flex;align-items:center;gap:5px;transition:all .15s;}
.btn-add:hover{background:var(--light);}
.btn-add .plus{color:var(--green);font-size:14px;}
.empty-state{text-align:center;padding:40px;color:#bbb;font-size:13px;}
.info-box{background:var(--light);border:1px solid var(--border);border-radius:10px;padding:14px 16px;font-size:13px;line-height:1.6;margin-bottom:16px;}
.info-box strong{color:var(--text);}

/* GitHub guide */
.gh-step{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:10px;}
.gh-step .step-num{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;background:#1a1a1a;color:#fff;border-radius:50%;font-size:11px;font-weight:700;margin-right:8px;}
.gh-step h4{font-size:13px;font-weight:700;display:inline;vertical-align:middle;}
.gh-step p{font-size:12px;color:var(--muted);margin-top:8px;line-height:1.6;}
.gh-step code{background:#f3f4f6;padding:1px 6px;border-radius:4px;font-family:monospace;font-size:12px;color:#333;}

@media(max-width:900px){
  .sidebar{width:60px;padding:14px 8px;}
  .brand-text,.nav-item span:not(.icon),.quick-actions h4,.btn-qa span:not(.plus){display:none;}
  .stat-row{grid-template-columns:1fr 1fr;}
  .two-col{grid-template-columns:1fr;}
  .chart-row{grid-template-columns:1fr 1fr;}
}
</style>
</head>
