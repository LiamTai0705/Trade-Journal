function filterTrades(q){
  const el=document.getElementById('tradesTableBody');
  if(!el)return;
  const filtered=trades.filter(t=>!q||t.inst.toLowerCase().includes(q.toLowerCase())||t.setup.toLowerCase().includes(q.toLowerCase())||t.dir.toLowerCase().includes(q.toLowerCase()));
  const sorted=[...filtered].sort((a,b)=>new Date(b.date)-new Date(a.date));
  el.innerHTML=`<table><thead><tr>
    <th>з·Ёиҷҹ</th><th>ж—Ҙжңҹ</th><th>е•Ҷе“Ғ</th><th>ж–№еҗ‘</th><th>зӯ–з•Ҙ</th><th>жҷӮж®ө</th>
    <th>RеҖҚж•ё</th><th>зӣҲиҷ§</th><th>и©•еҲҶ</th><th>зөҗжһң</th><th>жЁҷзұӨ</th>
  </tr></thead><tbody>
  ${sorted.map(t=>`<tr onclick="openModal('trade','${t.id}')">
    <td style="font-family:monospace;font-size:11px;color:#aaa">${t.id}</td>
    <td style="font-size:12px;color:#888">${t.date.slice(5)}</td>
    <td><strong>${t.inst}</strong></td>
    <td><span class="badge ${t.dir==='LONG'?'long':'short'}">${t.dir==='LONG'?'еӨҡ':'з©ә'}</span></td>
    <td style="font-size:11px;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${t.setup}">${t.setup.split(' ').slice(0,2).join(' ')}</td>
    <td style="font-size:11px;color:#888">${t.session}</td>
    <td style="font-weight:700;color:${t.r>=0?'#16a34a':'#dc2626'}">${t.r>0?'+':''}${t.r}R</td>
    <td class="${t.pl>=0?'pl-p':'pl-n'}">${fpl(t.pl)}</td>
    <td>${ratingBar(t.rating)}</td>
    <td><span class="badge ${t.result==='WIN'?'win':t.result==='LOSS'?'loss':'be'}">${t.result==='WIN'?'зҚІеҲ©':t.result==='LOSS'?'иҷ§жҗҚ':'дҝқжң¬'}</span></td>
    <td><div class="tag-wrap">${t.pos.map(p=>`<span class="tag pos">${p}</span>`).join('')}${t.neg.map(n=>`<span class="tag neg">${n}</span>`).join('')}</div></td>
  </tr>`).join('')||'<tr><td colspan="11" class="empty-state">жІ’жңүжүҫеҲ°з¬ҰеҗҲжўқд»¶зҡ„дәӨжҳ“гҖӮ</td></tr>'}
  </tbody></table>`;
}

