    el.classList.toggle('active', el.getAttribute('onclick')===`showTab('${tab}')`);
  });
  const area = document.getElementById('contentArea');
  if(tab==='dashboard') renderDashboard(area);
  else if(tab==='analytics') renderAnalytics(area);
  else if(tab==='review') renderReview(area);
  else if(tab==='trades') renderTrades(area);
