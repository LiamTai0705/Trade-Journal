function renderCalendar(){
  const sec=document.getElementById('calSection');
  if(!sec) return;
  const mt=getMonthTrades(viewYear,viewMonth);
  const s=calcStats(mt);
  const dayData={};
  mt.forEach(t=>{const k=new Date(t.date).getDate();if(!dayData[k])dayData[k]={pl:0,count:0};dayData[k].pl+=t.pl;dayData[k].count++;});
  const firstDow=new Date(viewYear,viewMonth,1).getDay();
  const startMon=(firstDow+6)%7; // Mon=0
  const daysInMonth=new Date(viewYear,viewMonth+1,0).getDate();
  const today=new Date();
  let cells=[];
  for(let i=0;i<startMon;i++) cells.push(null);
  for(let d=1;d<=daysInMonth;d++) cells.push(d);
  while(cells.length%5!==0) cells.push(null);

  let gridHtml='';
  for(let i=0;i<cells.length;i+=5){
    const week=cells.slice(i,i+5);
    let wPL=0,wCt=0;
    week.forEach(d=>{if(d&&dayData[d]){wPL+=dayData[d].pl;wCt+=dayData[d].count;}});
    week.forEach(d=>{
      if(!d){gridHtml+=`<div class="cal-cell empty"></div>`;return;}
      const isTd=today.getDate()===d&&today.getMonth()===viewMonth&&today.getFullYear()===viewYear;
      const cls=`cal-cell${dayData[d]?(dayData[d].pl>=0?' win':' loss'):''}${isTd?' today':''}`;
      gridHtml+=`<div class="${cls}">
        <div class="cal-d">${d}</div>
        ${dayData[d]?`<div class="cal-ct">${dayData[d].count}зӯҶ</div><div class="cal-pl ${dayData[d].pl>=0?'g':'r'}">${fpl(dayData[d].pl)}</div>`:''}
      </div>`;
    });
    gridHtml+=`<div class="cal-cell cal-sum">
      ${wCt>0?`<div class="sum-lbl">йҖұеҗҲиЁҲ</div><div class="sum-ct">${wCt}зӯҶ</div><div class="sum-pl ${wPL>=0?'pl-p':'pl-n'}">${fpl(wPL)}</div>`:''}
    </div>`;
  }
  sec.innerHTML=`<div class="cal-wrap">
    <div class="cal-topbar">
      <span class="title">${viewYear}е№ҙ ${MONTHS[viewMonth]}</span>
      <span class="cal-stats">P/L: <span class="gv">${fpl(s.totalPL)}</span> &nbsp; дәӨжҳ“: <span>${s.count}</span></span>
    </div>
    <div class="cal-header">
      <div class="cal-lbl">йҖұдёҖ</div><div class="cal-lbl">йҖұдәҢ</div>
      <div class="cal-lbl">йҖұдёү</div><div class="cal-lbl">йҖұеӣӣ</div>
      <div class="cal-lbl">йҖұдә”</div><div class="cal-lbl">йҖұеҗҲиЁҲ</div>
    </div>
    <div class="cal-grid">${gridHtml}</div>
  </div>`;
}

