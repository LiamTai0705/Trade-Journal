function fpl(v,dollar=true){
  const abs=Math.abs(v);
  const s = v>=0?'+':'-';
  const str = abs>=1000?(abs/1000).toFixed(1)+'K':abs.toFixed(0);
  return dollar ? s+'$'+str : s+str;
}
function getMonthTrades(y,m){ return trades.filter(t=>{const d=new Date(t.date);return d.getFullYear()===y&&d.getMonth()===m;}); }
function calcStats(trList){
  const wins=trList.filter(t=>t.result==='WIN').length;
  const losses=trList.filter(t=>t.result==='LOSS').length;
  const totalPL=trList.reduce((s,t)=>s+t.pl,0);
  const grossW=trList.filter(t=>t.pl>0).reduce((s,t)=>s+t.pl,0);
  const grossL=Math.abs(trList.filter(t=>t.pl<0).reduce((s,t)=>s+t.pl,0));
  const pf=grossL>0?(grossW/grossL):null;
  const avgR=trList.length?trList.reduce((s,t)=>s+t.r,0)/trList.length:0;
  const wr=trList.length?wins/trList.length*100:0;
  return {wins,losses,totalPL,pf,avgR,wr,count:trList.length};
}
function ratingBar(r){
  let h='<div class="rating-bar">';
  for(let i=1;i<=5;i++) h+=`<div class="rating-pip${i<=r?' on':''}"></div>`;
  return h+'</div>';
}
